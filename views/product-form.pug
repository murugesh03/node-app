doctype html
html
  head
    title Create Product
    style.
      body { font-family: Arial, sans-serif; max-width: 500px; margin: 40px auto; }
      form { display: flex; flex-direction: column; gap: 10px; }
      input, textarea, button, select { padding: 10px; }
      .message { padding: 10px; margin-bottom: 10px; border-radius: 6px; }
      .success { background: #e8f5e9; color: #2e7d32; }
      .error { background: #ffebee; color: #c62828; }
      .nav { margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; }
      .nav a { text-decoration: none; color: white; background: #2196F3; padding: 8px 12px; border-radius: 4px; font-size: 14px; }
      .nav a:hover { background: #0b7dda; }
      .nav a.logout { background: #dc3545; }
      .nav a.logout:hover { background: #c82333; }
  body
    .nav
      a(href='/dashboard') Dashboard
      a(href='/products') View Products
      a(href='/users') Manage Users
      if user
        span (logged in as #{user.email})
      a.logout(href='/logout') Logout
    h1 Create Product
    if message
      div(class=`message ${success ? 'success' : 'error'}`)= message
    form(method='POST' action='/products/new' enctype='multipart/form-data')
      input(type='number' name='id' placeholder='Product ID' required)
      input(type='text' name='name' placeholder='Product Name' required)
      textarea(name='description' placeholder='Description' required)
      input(type='number' step='0.01' name='price' placeholder='Price' required)
      input(type='text' name='category' placeholder='Category')
      input(type='number' name='phoneNumber' placeholder='Phone Number')
      input(type='file' name='image')
      button(type='submit') Save Product
    p
      a(href='/login') Back to Login
